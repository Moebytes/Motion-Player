{
  "name": "motion-player",
  "version": "0.9.9",
  "description": "A simple video player.",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "npm run clean && rsbuild build && electron dist/main/index.js",
    "build": "npm run clean ./build && rsbuild build && electron-builder -p never",
    "clean": "del-cli ./dist"
  },
  "keywords": [
    "video",
    "player",
    "reverse",
    "anime",
    "cute"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Moebytes/Motion-Player"
  },
  "build": {
    "appId": "com.moebytes.motion-player",
    "productName": "Motion Player",
    "icon": "./assets/icon.png",
    "directories": {
      "buildResources": "assets",
      "output": "build"
    },
    "buildDependenciesFromSource": true,
    "mac": {
      "target": {
        "target": "dmg",
        "arch": "arm64"
      },
      "category": "public.app-category.video",
      "extraFiles": [
        "ffmpeg/ffmpeg.app"
      ]
    },
    "dmg": {
      "title": "${productName}",
      "background": "./assets/background.png",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": {
        "target": "nsis",
        "arch": "x64"
      },
      "extraFiles": [
        "ffmpeg/ffmpeg.exe"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "Motion Player",
      "createDesktopShortcut": "always",
      "installerSidebar": "./assets/installer.bmp",
      "uninstallerSidebar": "./assets/installer.bmp"
    },
    "linux": {
      "target": {
        "target": "appImage",
        "arch": "x64"
      },
      "category": "Video",
      "extraFiles": [
        "ffmpeg/ffmpeg"
      ]
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "repo": "Motion-Player",
      "owner": "Moebytes",
      "releaseType": "draft"
    },
    "fileAssociations": [
      {
        "ext": "mp4",
        "description": "MP4 File"
      },
      {
        "ext": "webm",
        "description": "WEBM File"
      },
      {
        "ext": "mkv",
        "description": "MKV File"
      },
      {
        "ext": "mov",
        "description": "MOV File"
      },
      {
        "ext": "avi",
        "description": "AVI File"
      },
      {
        "ext": "m4v",
        "description": "M4V File"
      }
    ]
  },
  "author": "Moebytes",
  "license": "CC BY-NC 4.0",
  "devDependencies": {
    "@electron-rsbuild/plugin-main": "^0.0.12",
    "@electron-rsbuild/plugin-preload": "^0.0.12",
    "@electron-rsbuild/plugin-renderer": "^0.0.12",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-less": "^1.6.0",
    "@rsbuild/plugin-node-polyfill": "^1.4.4",
    "@rsbuild/plugin-react": "^1.4.5",
    "@rsbuild/plugin-type-check": "^1.3.3",
    "@svgr/webpack": "^8.1.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/react-slider": "^1.3.6",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "bootstrap": "^5.3.8",
    "electron-click-drag-plugin": "^2.0.2",
    "electron-shortcuts": "^0.4.0",
    "electron-store": "^8.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-redux": "^9.2.0",
    "react-slider": "^2.0.6",
    "youtube.ts": "^0.3.5"
  }
}
